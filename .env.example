# ---------- API ----------
# Porta do servidor Express
API_PORT=4000

# Origem do frontend (CORS)
WEB_ORIGIN=http://localhost:5173

# Segredo para assinar JWTs (gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=troque-este-valor-em-producao

# ID da planilha do Google Sheets (a parte entre /d/ e /edit na URL)
SHEETS_SPREADSHEET_ID=

# Credenciais da Service Account do Google Cloud.
# Opção 1: cole o JSON inteiro (em uma linha, com \n escapados) aqui:
GOOGLE_SERVICE_ACCOUNT_JSON=

# Opção 2 (alternativa): aponte para um arquivo local (não versionado):
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ---------- WEB ----------
# URL do backend consumida pelo frontend
VITE_API_URL=http://localhost:4000
